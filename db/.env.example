# Spine recording DB — environment variables.
#
# DEV-ONLY DEFAULTS. Copy to `.env` and edit before using in any non-local
# context. For central-server / production deployments, generate strong
# credentials and inject them via your secrets manager — do NOT commit
# real credentials to this repo.

# Postgres server (consumed by the postgres service)
POSTGRES_DB=spine
POSTGRES_USER=spine
POSTGRES_PASSWORD=spine_dev_only

# Host port the Spine Postgres binds to on 127.0.0.1. Set to 33000 so we
# stay out of the way of any host-installed Postgres on 5432 (Postgres.app,
# apt-installed, another project's docker stack) AND of the common
# alternate 5433. Change this only if you need a different port.
POSTGRES_HOST_PORT=33000

# Hostname/IP that Postgres binds to on the host. Default 127.0.0.1
# (localhost only). Set to 0.0.0.0 to expose to your LAN so other
# machines can connect and join the fleet. Use a reverse proxy + TLS
# for anything beyond a trusted LAN.
POSTGRES_BIND_HOST=127.0.0.1

# Flyway client (consumed by the flyway service)
# Host is `postgres` because both containers share the `spine_net` network.
FLYWAY_URL=jdbc:postgresql://postgres:5432/spine
FLYWAY_USER=spine
FLYWAY_PASSWORD=spine_dev_only
