.DS_Store
*.swp
*.swo
*~

# Local Spine install onto this repo (regenerate with: bash install.sh .)
.planning/

# v3 dogfood workspaces + scratch (#34) — never commit
.spine/

# Local agent IDE config (not platform code)
.agents/
.claude/
skills-lock.json

# Copies of lib/*.sh — created by install.sh into scripts/
scripts/
# SPA codegen scripts are tracked (per Wave 3 part 2 Squad SPA3)
!shared/ui/spa/scripts/
!shared/ui/spa/scripts/*

# Python venv (per-machine; created during dogfood / dev)
.venv/
*/__pycache__/
__pycache__/

# Per v3 design decision #9 (vault-only secrets, no exceptions):
# any local plaintext .env under verify/ is forbidden. The
# vault-reference manifest (verify/.env.vault-refs) and the
# non-secret example (verify/.env.example) are explicitly allowed.
verify/.env
verify/.env.local
verify/.env.production
!verify/.env.example
!verify/.env.vault-refs
