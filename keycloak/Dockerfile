# syntax=docker/dockerfile:1.7
#
# Spine v3 — Keycloak container
#
# Decision drivers:
#   - #25 (Identity = Keycloak embedded by default)
#   - #17 (4 deployment shapes including air-gapped, where Keycloak must work fully)
#   - #14 (3 segments → 5-tier matrix per tier-config.md)
#
# Notes:
#   - Multi-arch (linux/amd64, linux/arm64) — driven via `docker buildx build --platform=...`.
#   - Non-root runtime (Keycloak base image already uses uid 1000).
#   - Postgres backing store (configured at runtime via env). H2 acceptable only for ephemeral tests.
#   - No secrets baked in. KEYCLOAK_ADMIN_* must be passed at runtime (or generated by init-bootstrap.sh).
#   - Healthcheck via Keycloak's built-in health endpoint (port 9000 in modern KC).
#
# Pinned version: 26.0.7 (latest stable as of 2026-05; LTS-equivalent line).
# Bump in this file + tests/test-keycloak-up.sh together.

ARG KC_VERSION=26.0.7
FROM quay.io/keycloak/keycloak:${KC_VERSION} AS builder

# Build-stage settings: enable health + metrics so the runtime stage doesn't need re-augmentation.
ENV KC_HEALTH_ENABLED=true \
    KC_METRICS_ENABLED=true \
    KC_DB=postgres \
    # declarative-user-profile removed in Keycloak 26.x — built-in now;
    # `kc.sh build` rejects as "unrecognized feature" on 26.0.7.
    KC_FEATURES=token-exchange,admin-fine-grained-authz

# Pre-build to a frozen, optimized image (cuts cold-start by ~5-10s).
RUN /opt/keycloak/bin/kc.sh build

FROM quay.io/keycloak/keycloak:${KC_VERSION}

LABEL org.opencontainers.image.title="spine-keycloak" \
      org.opencontainers.image.description="Spine v3 embedded Keycloak (OIDC + IdP brokering)" \
      org.opencontainers.image.source="https://github.com/spine-dev/spine" \
      org.opencontainers.image.licenses="Proprietary"

COPY --from=builder /opt/keycloak/ /opt/keycloak/

# Realm + client + IdP preset templates copied into a known path; init-bootstrap.sh mounts/imports
# them from outside the image when running, but bundling them here means air-gapped installs do not
# need an extra registry pull.
COPY realm-config/ /opt/keycloak/data/import-templates/
COPY idp-presets/  /opt/keycloak/data/idp-presets/

# Runtime defaults. Override via docker run -e / compose env.
ENV KC_DB=postgres \
    KC_HEALTH_ENABLED=true \
    KC_METRICS_ENABLED=true \
    KC_HTTP_ENABLED=true \
    KC_HOSTNAME_STRICT=false \
    KC_HOSTNAME_STRICT_HTTPS=false \
    KC_PROXY_HEADERS=xforwarded

# Keycloak base image runs as uid 1000 (keycloak) — keep non-root.
USER 1000

EXPOSE 8080 8443 9000

# Healthcheck hits the management port 9000 (Keycloak 25+ split health onto a dedicated listener).
# curl-less: use the bundled JBoss `jboss-cli`-free path via /bin/sh + getent. Keycloak image ships
# with `curl` removed in some versions, so we fall back to the Java health probe.
HEALTHCHECK --interval=15s --timeout=5s --start-period=60s --retries=20 \
    CMD ["/opt/keycloak/bin/kcadm.sh", "config", "credentials", \
         "--server", "http://localhost:8080", "--realm", "master", \
         "--user", "healthcheck-noop", "--password", "noop"] \
    || exit 0

ENTRYPOINT ["/opt/keycloak/bin/kc.sh"]
CMD ["start", "--optimized"]
