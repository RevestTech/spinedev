{
  "_comment_top": "Spine v3 — OneLogin IdP brokering preset. Day-0 wizard substitutes placeholders. {{ONELOGIN_SUBDOMAIN}} = the customer's OneLogin subdomain (e.g. 'acme' → acme.onelogin.com).",
  "_comment_placeholders": {
    "{{ONELOGIN_SUBDOMAIN}}": "Customer's OneLogin subdomain (e.g. 'acme' — bare, no .onelogin.com)",
    "{{CLIENT_ID}}": "OIDC app Client ID from OneLogin admin",
    "{{CLIENT_SECRET_PATH_IN_VAULT}}": "Vault path, e.g. 'secret/spine/idp/onelogin/client-secret'"
  },
  "alias": "onelogin",
  "displayName": "OneLogin",
  "providerId": "oidc",
  "enabled": true,
  "updateProfileFirstLoginMode": "on",
  "trustEmail": true,
  "storeToken": false,
  "addReadTokenRoleOnCreate": false,
  "authenticateByDefault": false,
  "linkOnly": false,
  "firstBrokerLoginFlowAlias": "first broker login",
  "config": {
    "issuer": "https://{{ONELOGIN_SUBDOMAIN}}.onelogin.com/oidc/2",
    "authorizationUrl": "https://{{ONELOGIN_SUBDOMAIN}}.onelogin.com/oidc/2/auth",
    "tokenUrl": "https://{{ONELOGIN_SUBDOMAIN}}.onelogin.com/oidc/2/token",
    "userInfoUrl": "https://{{ONELOGIN_SUBDOMAIN}}.onelogin.com/oidc/2/me",
    "logoutUrl": "https://{{ONELOGIN_SUBDOMAIN}}.onelogin.com/oidc/2/logout",
    "jwksUrl": "https://{{ONELOGIN_SUBDOMAIN}}.onelogin.com/oidc/2/certs",
    "useJwksUrl": "true",
    "validateSignature": "true",
    "clientId": "{{CLIENT_ID}}",
    "clientSecret": "${vault.{{CLIENT_SECRET_PATH_IN_VAULT}}}",
    "clientAuthMethod": "client_secret_post",
    "defaultScope": "openid profile email groups",
    "syncMode": "FORCE",
    "pkceEnabled": "true",
    "pkceMethod": "S256",
    "prompt": "select_account"
  }
}
