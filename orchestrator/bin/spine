#!/usr/bin/env bash
# spine — Spine orchestrator user CLI. STORY-9.9.3, PRD REQ-INIT-9 §9.5 FR-10.
# Thin wrapper over MCP (STORY-9.9.1): mutations go through `_mcp_call`;
# reads use psql against `spine_lifecycle` / `spine_audit`. Subsystems are
# reached only through MCP (PRD FR-5). See `spine help` / bin/README.md.
set -euo pipefail
IFS=$'\n\t'

# Load db/.env (POSTGRES_*) → SPINE_DB_URL. Sourcing the loader keeps the
# bash CLI in sync with the `make up` Postgres regardless of which port +
# password the operator chose. Fixes wave-8 smoke F6/F8/F9.
# shellcheck source=../lib/_env_loader.sh
. "$(cd "$(dirname "${BASH_SOURCE[0]}")/../lib" && pwd)/_env_loader.sh"
SPINE_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
# SPINE_MCP_HTTP_URL is *not* defaulted: an unset value means "no HTTP
# transport configured" (try in-process Python instead). Default-on would
# hide the legitimate dev case where there's no MCP server running.
SPINE_DEFAULT_BUNDLE="${SPINE_DEFAULT_BUNDLE:-}"
SPINE_DEFAULT_OWNER="${SPINE_DEFAULT_OWNER:-${USER:-unknown}}"

# Pick a Python: project venv takes precedence so the deps installed by
# `python3 -m venv .venv && .venv/bin/pip install …` are visible without
# having to activate first.
if [[ -x "$SPINE_HOME/.venv/bin/python3" ]]; then _SPINE_PY="$SPINE_HOME/.venv/bin/python3"
elif command -v python3 >/dev/null 2>&1; then    _SPINE_PY="$(command -v python3)"
else _SPINE_PY=""; fi

QUIET=0; VERBOSE=0; DRY_RUN=0; FORMAT=human

if [[ -t 1 ]]; then C_G=$(tput setaf 2 2>/dev/null||:); C_Y=$(tput setaf 3 2>/dev/null||:)
  C_R=$(tput setaf 1 2>/dev/null||:); C_D=$(tput dim 2>/dev/null||:); C_X=$(tput sgr0 2>/dev/null||:)
else C_G=""; C_Y=""; C_R=""; C_D=""; C_X=""; fi

_log() { printf '%s spine %s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$1" "${*:2}" >&2; }
_dbg() { [[ $VERBOSE -eq 1 ]] && _log DEBUG "$*"; return 0; }
_die() { local c="$1"; shift; printf '%s%s%s\n' "$C_R" "$*" "$C_X" >&2; exit "$c"; }
_jq()  { printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'; }
_sql() { printf '%s' "$1" | sed "s/'/''/g"; }
_psql(){ psql "$SPINE_DB_URL" -A -t -X -q -v ON_ERROR_STOP=1 "$@"; }

# MCP transport — three options, tried in this order:
#   1. `mcp` CLI on PATH (stdio) — purpose-built, fastest
#   2. in-process Python (loads shared.mcp.tools and calls the tool fn
#      directly) — works in any dev/repo context with python3 available;
#      same code the server would run, just no socket in between
#   3. HTTP only if SPINE_MCP_HTTP_URL is explicitly set — note the
#      current FastMCP HTTP transport is Streamable-HTTP (session-based)
#      and a raw POST won't work; left as an escape hatch for a future
#      REST gateway or stub server
# Exit 4 if none reachable.
_mcp_inprocess_call() {
  local tool="$1" payload="$2"
  SPINE_TOOL="$tool" SPINE_PAYLOAD="$payload" SPINE_HOME="$SPINE_HOME" \
    "$_SPINE_PY" - <<'PY'
import json, os, sys, traceback
# Put SPINE_HOME first (shared.*, plan.*, build.*) and verify/ second so
# TRON's absolute `tron.*` imports resolve (verify/tron/...). The wrapper
# `shared.mcp.tools.verify` also uses `verify.tron.*` imports — those work
# via the implicit-namespace package because verify/ has no __init__.py.
# Wiring documented in verify/SUBSYSTEM_BOUNDARY.md §"Standalone deployability".
sys.path.insert(0, os.environ["SPINE_HOME"])
sys.path.insert(1, os.path.join(os.environ["SPINE_HOME"], "verify"))
try:
    from shared.secrets import SecretAdapter, SecretNotFound, set_default_adapter
    class FileSecretsAdapter(SecretAdapter):
        name = "file"
        def __init__(self, filepath: str) -> None:
            self.filepath = filepath
        def _read(self) -> dict[str, str]:
            if not os.path.exists(self.filepath):
                return {}
            try:
                with open(self.filepath, "r", encoding="utf-8") as f:
                    return json.load(f)
            except Exception:
                return {}
        def _write(self, store: dict[str, str]) -> None:
            os.makedirs(os.path.dirname(self.filepath), exist_ok=True)
            with open(self.filepath, "w", encoding="utf-8") as f:
                json.dump(store, f)
        async def get(self, path: str) -> str:
            store = self._read()
            if path in store:
                return store[path]
            raise SecretNotFound(path)
        async def put(self, path: str, value: str) -> None:
            store = self._read()
            store[path] = value
            self._write(store)
        async def delete(self, path: str) -> None:
            store = self._read()
            if path in store:
                del store[path]
                self._write(store)
        async def list(self, prefix: str = "") -> list[str]:
            store = self._read()
            return sorted(k for k in store if k.startswith(prefix))
    set_default_adapter(FileSecretsAdapter(os.path.join(os.environ["SPINE_HOME"], ".spine", "mock_secrets.json")))
except Exception as e:
    print(json.dumps({"status": "error", "error": f"secrets_bootstrap_failed: {e}", "data": None}))
    sys.exit(0)

try:
    from shared.mcp.tools import TOOL_REGISTRY, discover_tools
except Exception as e:
    print(json.dumps({"status": "error", "error": f"import_failed: {e}", "data": None}))
    sys.exit(0)
discover_tools()
name = os.environ["SPINE_TOOL"]
spec = TOOL_REGISTRY.get(name)
if spec is None:
    print(json.dumps({"status": "error", "error": f"unknown_tool: {name}", "data": None}))
    sys.exit(0)
try:
    payload = spec.input_model.model_validate_json(os.environ["SPINE_PAYLOAD"])
    result = spec.fn(payload)
except Exception as e:
    print(json.dumps({"status": "error", "error": str(e),
                      "data": None, "trace": traceback.format_exc()}))
    sys.exit(0)
if hasattr(result, "model_dump_json"):
    print(result.model_dump_json())
elif hasattr(result, "model_dump"):
    print(json.dumps(result.model_dump(mode="json"), default=str))
else:
    print(json.dumps(result, default=str))
PY
}

_mcp_call() {
  local tool="$1" payload="$2"
  _dbg "mcp_call tool=$tool payload=$payload"
  [[ $DRY_RUN -eq 1 ]] && { printf '{"ok":true,"dry_run":true,"tool":"%s","payload":%s}\n' "$tool" "$payload"; return 0; }
  if command -v mcp >/dev/null 2>&1; then
    mcp call "$tool" --json "$payload" 2>/dev/null \
      || { _log ERROR "mcp $tool (stdio) failed"; return 4; }
  elif [[ -n "$_SPINE_PY" && -d "$SPINE_HOME/shared/mcp" ]]; then
    _mcp_inprocess_call "$tool" "$payload" \
      || { _log ERROR "mcp $tool (in-process python) failed"; return 4; }
  elif [[ -n "${SPINE_MCP_HTTP_URL:-}" ]] && command -v curl >/dev/null 2>&1; then
    curl -fsS -H 'Content-Type: application/json' \
      -X POST "$SPINE_MCP_HTTP_URL/tools/$tool" --data "$payload" \
      || { _log ERROR "mcp $tool (http) failed — note FastMCP needs Streamable-HTTP, raw POST won't work"; return 4; }
  else
    _die 4 "no mcp transport reachable: install 'mcp' CLI, run from a Spine repo with python3, or set SPINE_MCP_HTTP_URL"
  fi
}

_emit() { case "$FORMAT" in
  json)  printf '%s\n' "$1" ;;
  brief) printf '%s\n' "$1" | sed -e 's/[{}"]//g' -e 's/,/  /g' ;;
  *)     if command -v jq >/dev/null 2>&1; then printf '%s\n' "$1" | jq .; else printf '%s\n' "$1"; fi ;;
esac; }

# Global-flag parser: strips known flags, leaves positional args in REST_ARGS.
declare -a REST_ARGS=()
_parse_flags() {
  REST_ARGS=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)    REST_ARGS+=("--help"); shift ;;
      -q|--quiet)   QUIET=1; shift ;;
      -v|--verbose) VERBOSE=1; shift ;;
      --dry-run)    DRY_RUN=1; shift ;;
      --format)     FORMAT="${2:-human}"; shift 2 ;;
      --format=*)   FORMAT="${1#--format=}"; shift ;;
      --)           shift; REST_ARGS+=("$@"); break ;;
      *)            REST_ARGS+=("$1"); shift ;;
    esac
  done
}

# _flag_val --name → echoes value, strips `--name V` and `--name=V` from REST_ARGS.
_flag_val() {
  local want="$1" out="" i=0 keep=()
  while [[ $i -lt ${#REST_ARGS[@]} ]]; do
    if   [[ "${REST_ARGS[$i]}" == "$want"    ]]; then out="${REST_ARGS[$((i+1))]:-}"; i=$((i+2)); continue
    elif [[ "${REST_ARGS[$i]}" == "$want="*  ]]; then out="${REST_ARGS[$i]#$want=}";  i=$((i+1)); continue; fi
    keep+=("${REST_ARGS[$i]}"); i=$((i+1))
  done
  # `${keep[@]}` is undefined under `set -u` when the array is empty on
  # bash 3.2; guard with `${keep[@]+...}` (param-set expansion).
  REST_ARGS=(${keep[@]+"${keep[@]}"}); printf '%s' "$out"
}

# Helper to slice REST_ARGS safely under custom IFS
_slice_rest_args() {
  local count="${1:-1}"
  local old_ifs="$IFS"
  IFS=$' \t\n'
  REST_ARGS=("${REST_ARGS[@]:$count}")
  IFS="$old_ifs"
}

_help_for() { case "$1" in
  new)      echo "spine project new <name> [--type greenfield|evolve|audit_only|operate] [--description D] [--bundle B] [--owner E]";;
  status)   echo "spine project status <id> [--watch] [--format json|table|brief]";;
  approve)  echo "spine project approve <id> <phase> [--notes N] [--approver A]";;
  reject)   echo "spine project reject  <id> <phase> --reason R [--approver A]";;
  rollback) echo "spine project rollback <id> <target_phase> --reason R";;
  list)     echo "spine project list [--phase P] [--status active|paused|terminated|completed]";;
  show)     echo "spine project show <id>";; audit) echo "spine project audit <id> [--export csv|json]";;
  intake)   echo "spine intake <project_id> [--template T] [--actor A]";;
  build-brief)  echo "spine build brief <project_id>";;
  build-report) echo "spine build report <project_id> --artifact <path> [--actor A]";;
  harness-init)   echo "spine harness init [--project PATH] [--symlink-skills]";;
  harness-start)  echo "spine harness start <mode> [--project PATH]";;
  harness-loop)   echo "spine harness loop <interval> <mode> [--project PATH]";;
  harness-status) echo "spine harness status [--markdown] [--project PATH]";;
  harness-verify) echo "spine harness verify [--roles qa,auditor] [--run-qa] [--markdown] [--project PATH]";;
  harness-stop)   echo "spine harness stop [--project PATH]";;
  *) return 1 ;;
esac; }

# ─── project: mutating → MCP ──────────────────────────────────────────
cmd_project_new() {
  [[ "${REST_ARGS[0]:-}" == "--help" || ${#REST_ARGS[@]} -eq 0 ]] && { _help_for new >&2; return 0; }
  local name="${REST_ARGS[0]}"; _slice_rest_args 1
  [[ -z "$name" ]] && _die 2 "project new: <name> required"
  local ptype owner desc bundle p
  ptype="$(_flag_val --type)";       ptype="${ptype:-greenfield}"
  owner="$(_flag_val --owner)";      owner="${owner:-$SPINE_DEFAULT_OWNER}"
  desc="$(_flag_val --description)"; bundle="$(_flag_val --bundle)"; bundle="${bundle:-$SPINE_DEFAULT_BUNDLE}"
  p=$(printf '{"name":"%s","project_type":"%s","owner":"%s"' "$(_jq "$name")" "$ptype" "$(_jq "$owner")")
  [[ -n "$desc"   ]] && p+=$(printf ',"description":"%s"' "$(_jq "$desc")")
  [[ -n "$bundle" ]] && p+=$(printf ',"bundle":"%s"'      "$(_jq "$bundle")")
  _emit "$(_mcp_call project_create "${p}}")"
}

cmd_project_status() {
  [[ "${REST_ARGS[0]:-}" == "--help" ]] && { _help_for status >&2; return 0; }
  local watch=0 kept=()
  for a in "${REST_ARGS[@]}"; do [[ "$a" == "--watch" ]] && watch=1 || kept+=("$a"); done
  REST_ARGS=("${kept[@]}")
  local pid="${REST_ARGS[0]:-}"; [[ -z "$pid" ]] && _die 2 "project status: <project_id> required"
  while :; do
    _emit "$(_mcp_call project_status "$(printf '{"project_id":"%s"}' "$(_jq "$pid")")")"
    [[ $watch -eq 0 ]] && break; sleep 5; [[ -t 1 ]] && clear || true
  done
}

cmd_project_approve() {
  [[ "${REST_ARGS[0]:-}" == "--help" ]] && { _help_for approve >&2; return 0; }
  local pid="${REST_ARGS[0]:-}" phase="${REST_ARGS[1]:-}"
  [[ -z "$pid" || -z "$phase" ]] && _die 2 "approve: <project_id> <phase> required"
  _slice_rest_args 2
  local notes approver p grant tok
  notes="$(_flag_val --notes)"
  approver="$(_flag_val --approver)"; approver="${approver:-$SPINE_DEFAULT_OWNER}"
  p=$(printf '{"project_id":"%s","phase":"%s","approver":"%s"' "$(_jq "$pid")" "$(_jq "$phase")" "$(_jq "$approver")")
  [[ -n "$notes" ]] && p+=$(printf ',"notes":"%s"' "$(_jq "$notes")")
  grant="$(_mcp_call approval_grant "${p}}")" || return $?
  _emit "$grant"
  tok="$(printf '%s' "$grant" | sed -n 's/.*"token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
  _emit "$(_mcp_call phase_advance "$(printf '{"project_id":"%s","target_phase":"%s","approval_token":"%s"}' \
    "$(_jq "$pid")" "$(_jq "$phase")" "$(_jq "$tok")")")"
}

cmd_project_reject() {
  [[ "${REST_ARGS[0]:-}" == "--help" ]] && { _help_for reject >&2; return 0; }
  local pid="${REST_ARGS[0]:-}" phase="${REST_ARGS[1]:-}" reason approver
  [[ -z "$pid" || -z "$phase" ]] && _die 2 "reject: <project_id> <phase> required"
  _slice_rest_args 2
  reason="$(_flag_val --reason)"; [[ -z "$reason" ]] && _die 2 "reject: --reason required"
  approver="$(_flag_val --approver)"; approver="${approver:-$SPINE_DEFAULT_OWNER}"
  _emit "$(_mcp_call gate_reject "$(printf '{"project_id":"%s","phase":"%s","approver":"%s","decision":"rejected","reason":"%s"}' \
    "$(_jq "$pid")" "$(_jq "$phase")" "$(_jq "$approver")" "$(_jq "$reason")")")"
}

cmd_project_rollback() {
  [[ "${REST_ARGS[0]:-}" == "--help" ]] && { _help_for rollback >&2; return 0; }
  local pid="${REST_ARGS[0]:-}" target="${REST_ARGS[1]:-}" reason
  [[ -z "$pid" || -z "$target" ]] && _die 2 "rollback: <project_id> <target_phase> required"
  _slice_rest_args 2
  reason="$(_flag_val --reason)"; [[ -z "$reason" ]] && _die 2 "rollback: --reason required"
  _emit "$(_mcp_call phase_advance "$(printf '{"project_id":"%s","target_phase":"%s","rollback":true,"reason":"%s"}' \
    "$(_jq "$pid")" "$(_jq "$target")" "$(_jq "$reason")")")"
}

# ─── project: read-side → direct SQL ──────────────────────────────────
cmd_project_list() {
  local phase status where="" sql
  phase="$(_flag_val --phase)";   [[ -n "$phase"  ]] && where+=" AND current_phase = '$(_sql "$phase")'"
  status="$(_flag_val --status)"; [[ -n "$status" ]] && where+=" AND status        = '$(_sql "$status")'"
  sql="SELECT id, name, project_type, current_phase, status, created_at::text FROM spine_lifecycle.project
        WHERE TRUE $where ORDER BY created_at DESC;"
  if [[ "$FORMAT" == "json" ]]
  then _psql -c "SELECT jsonb_agg(row_to_json(t)) FROM ($sql) t;" 2>/dev/null || _die 4 "db unreachable"
  else { printf 'id|name|type|phase|status|created_at\n'; _psql -c "$sql" 2>/dev/null; } \
         | column -t -s'|' || _die 4 "db unreachable"; fi
}

cmd_project_show() {
  local pid="${REST_ARGS[0]:-}"; [[ -z "$pid" ]] && _die 2 "show: <project_id> required"
  _emit "$(_mcp_call project_status "$(printf '{"project_id":"%s"}' "$(_jq "$pid")")")"
  [[ "$FORMAT" == "json" ]] && return 0
  printf '\n%sTransitions%s\n' "$C_D" "$C_X"
  _psql -c "SELECT created_at::text, from_phase, to_phase, actor, decision FROM spine_lifecycle.transition
    WHERE project_id::text = '$(_sql "$pid")' ORDER BY created_at DESC LIMIT 20;" 2>/dev/null | column -t -s'|' || true
}

cmd_project_audit() {
  local pid="${REST_ARGS[0]:-}"; [[ -z "$pid" ]] && _die 2 "audit: <project_id> required"
  _slice_rest_args 1; local fmt sql
  fmt="$(_flag_val --export)"
  sql="SELECT created_at::text, action, phase, actor, rationale FROM spine_audit.events
        WHERE project_id::text = '$(_sql "$pid")' ORDER BY created_at DESC;"
  case "$fmt" in
    csv)  _psql --csv -c "$sql" 2>/dev/null || _die 4 "audit query failed" ;;
    json) _psql -c "SELECT jsonb_agg(row_to_json(t)) FROM ($sql) t;" 2>/dev/null || _die 4 "audit query failed" ;;
    *)    _psql -c "$sql" 2>/dev/null | column -t -s'|' || _die 4 "audit query failed" ;;
  esac
}

# ─── intake — interactive Q&A for plan_in_progress (STORY-9.4.1) ───
# Run the plan/runtime/intake_runner loop with stdin attached so the user
# can answer questions. We bypass _mcp_call here because that path uses a
# heredoc to feed the Python interpreter — which closes stdin. Instead we
# import the runner module directly and let it read from the real tty.
cmd_intake() {
  [[ "${REST_ARGS[0]:-}" == "--help" || ${#REST_ARGS[@]} -eq 0 ]] && {
    _help_for intake >&2; return 0; }
  local pid="${REST_ARGS[0]}"; _slice_rest_args 1
  [[ -z "$pid" ]] && _die 2 "intake: <project_id> required"
  local template actor
  template="$(_flag_val --template)"
  actor="$(_flag_val --actor)"; actor="${actor:-product}"
  [[ -z "$_SPINE_PY" ]] && _die 4 "intake: python3 unavailable"
  SPINE_INTAKE_PID="$pid" SPINE_INTAKE_TEMPLATE="$template" \
  SPINE_INTAKE_ACTOR="$actor" SPINE_HOME="$SPINE_HOME" \
    "$_SPINE_PY" -c "$(cat <<'PY'
import os, sys
sys.path.insert(0, os.environ["SPINE_HOME"])
from plan.runtime.intake_runner import (
    run_intake, IntakeNotInteractive, IntakeTemplateNotFound,
)
pid = os.environ["SPINE_INTAKE_PID"]
tpl = os.environ.get("SPINE_INTAKE_TEMPLATE") or None
actor = os.environ.get("SPINE_INTAKE_ACTOR") or "product"
try:
    result = run_intake(pid, template=tpl, actor=actor)
except IntakeNotInteractive as exc:
    print(f"error: {exc}", file=sys.stderr); sys.exit(3)
except IntakeTemplateNotFound as exc:
    print(f"error: {exc}", file=sys.stderr); sys.exit(2)
print(f"\nintake_runner: template={result.template} answers={len(result.answers)} "
      f"prd_valid={result.prd_valid} audit_events={result.audit_event_count}")
PY
)"
}

# ─── build — show brief / ingest a BuildArtifact (STORY-7.2.2/7.2.3) ──
# `build brief` prints metadata.build_brief for human review. `build report`
# reads a BuildArtifact JSON file and pushes it through `build_completed`
# via the same in-process MCP transport used everywhere else.
cmd_build_brief() {
  [[ "${REST_ARGS[0]:-}" == "--help" || ${#REST_ARGS[@]} -eq 0 ]] && {
    _help_for build-brief >&2; return 0; }
  local pid="${REST_ARGS[0]}"
  [[ -z "$pid" ]] && _die 2 "build brief: <project_id> required"
  local sql out
  sql="SELECT metadata->'build_brief' FROM spine_lifecycle.project
        WHERE (id::text = '$(_sql "$pid")' OR name = '$(_sql "$pid")'
               OR project_uuid::text = '$(_sql "$pid")') AND status='active' LIMIT 1;"
  out="$(_psql -c "$sql" 2>/dev/null | sed -e 's/^ *//' -e 's/ *$//')"
  if [[ -z "$out" || "$out" == "null" ]]; then
    printf '%sno build_brief for project %s — run `spine project status %s` and dispatch build first%s\n' \
      "$C_Y" "$pid" "$pid" "$C_X" >&2
    return 3
  fi
  _emit "$out"
}

cmd_build_report() {
  [[ "${REST_ARGS[0]:-}" == "--help" || ${#REST_ARGS[@]} -eq 0 ]] && {
    _help_for build-report >&2; return 0; }
  local pid="${REST_ARGS[0]}"
  [[ -z "$pid" ]] && _die 2 "build report: <project_id> required"
  # Walk a local snapshot ourselves instead of `$(_flag_val …)` — that
  # forks a subshell, the subshell's REST_ARGS=(…) write doesn't reach
  # the parent, and on bash 3.2 the subshell-printed value occasionally
  # comes back empty under file-level `IFS=$'\n\t'`. Tracked as Bug 5.
  local artifact="" actor="" payload result status arg
  local -a _ba_left=()
  local _i=1
  while (( _i < ${#REST_ARGS[@]} )); do
    arg="${REST_ARGS[$_i]}"
    case "$arg" in
      --artifact)     artifact="${REST_ARGS[$((_i+1))]:-}"; _i=$((_i+2)) ;;
      --artifact=*)   artifact="${arg#--artifact=}";        _i=$((_i+1)) ;;
      --actor)        actor="${REST_ARGS[$((_i+1))]:-}";    _i=$((_i+2)) ;;
      --actor=*)      actor="${arg#--actor=}";              _i=$((_i+1)) ;;
      *)              _ba_left+=("$arg");                   _i=$((_i+1)) ;;
    esac
  done
  REST_ARGS=(${_ba_left[@]+"${_ba_left[@]}"})
  actor="${actor:-build}"
  [[ -z "$artifact" ]] && _die 2 "build report: --artifact <path> required"
  [[ -f "$artifact" ]] || _die 2 "build report: artifact file not found: $artifact"
  # Embed the file content as the `artifact` field. Python on the other side
  # does the JSON parse + BuildArtifact.model_validate, so we just need the
  # outer envelope to be valid JSON.
  if ! payload="$("$_SPINE_PY" - <<PY
import json, sys
with open("$artifact","r",encoding="utf-8") as f:
    art = json.load(f)
print(json.dumps({"project_id": "$pid", "actor": "$actor", "artifact": art}))
PY
)"; then
    _die 2 "build report: failed to load/parse artifact JSON at $artifact"
  fi
  result="$(_mcp_call build_completed "$payload")" || return $?
  _emit "$result"
  # Exit 3 if the tool returned status=error so scripts can branch on it.
  status="$(printf '%s' "$result" | sed -n 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
  [[ "$status" == "error" ]] && return 3
  return 0
}

# ─── portfolio + doctor + help ────────────────────────────────────────
cmd_status() {
  # Markdown handoff mode — V3 B5 (ECC borrow). Renders a portable
  # SESSION_HANDOFF-style snapshot. Supports `--write PATH` and
  # `--exit-code` (0=green / 1=warnings / 2=failures).
  local md_flag=0
  # `${REST_ARGS[@]}` is unset under bash 3.2 + `set -u` when the array is
  # empty; guard with the param-set expansion to match the rest of this CLI.
  for a in ${REST_ARGS[@]+"${REST_ARGS[@]}"}; do
    [[ "$a" == "--markdown" ]] && md_flag=1
  done
  if [[ $md_flag -eq 1 ]]; then
    local write_path exit_code_flag ledger_root
    write_path="$(_flag_val --write)"
    ledger_root="$(_flag_val --ledger-root)"
    exit_code_flag=0
    # Strip the --markdown flag now that downstream flags are read.
    local i=0; local -a keep=()
    while [[ $i -lt ${#REST_ARGS[@]} ]]; do
      if   [[ "${REST_ARGS[$i]}" == "--markdown" ]]; then i=$((i+1)); continue
      elif [[ "${REST_ARGS[$i]}" == "--exit-code" ]]; then
        exit_code_flag=1; i=$((i+1)); continue
      fi
      keep+=("${REST_ARGS[$i]}"); i=$((i+1))
    done
    REST_ARGS=(${keep[@]+"${keep[@]}"})

    if [[ -z "$_SPINE_PY" ]]; then
      _die 4 "python3 not available; cannot render markdown handoff"
    fi
    local -a py_args=(-m orchestrator.cli.status_markdown)
    [[ -n "$write_path" ]] && py_args+=(--write "$write_path")
    [[ -n "$ledger_root" ]] && py_args+=(--ledger-root "$ledger_root")
    [[ $exit_code_flag -eq 1 ]] && py_args+=(--exit-code)

    SPINE_HOME="$SPINE_HOME" SPINE_DB_URL="${SPINE_DB_URL:-}" \
      SPINE_DECISION_LEDGER_ROOT="${SPINE_DECISION_LEDGER_ROOT:-}" \
      "$_SPINE_PY" "${py_args[@]}"
    return $?
  fi

  # Default: terse phase-count table (backcompat).
  { printf 'phase|count\n'; _psql -c "SELECT current_phase, COUNT(*) FROM spine_lifecycle.project
      GROUP BY current_phase ORDER BY current_phase;" 2>/dev/null; } \
    | column -t -s'|' || _die 4 "db unreachable at $SPINE_DB_URL"
}

# cmd_doctor — extended in M.bootstrap. Checks (in order, fail-fast on env):
#   1. binaries on PATH: docker, python3>=3.10, psql, jq (warn-only)
#   2. .venv + critical python imports (mcp, pydantic, yaml, shared.mcp tools)
#   3. spine postgres reachable
#   4. spine schemas present (the 9 spine_* schemas — mirrors smoke phase 2)
#   5. tron postgres reachable (spine_tron_postgres on 33010)
#   6. tron importable (tron.agents.manager.AuditManager — mirrors phase 11.3)
#   7. mcp transport (stdio CLI > in-process python > HTTP)
#   8. bundle config (SPINE_DEFAULT_BUNDLE)
#   9. api keys (ANTHROPIC_API_KEY / OPENAI_API_KEY — INFO, never FAIL)
# Pass --verbose for remediation hints on any non-OK row.
# Exit: 0 = all ok, 1 = warns only, 4 = any FAIL.
cmd_doctor() {
  # `--verbose`/`-v` is consumed by the global `_parse_flags`, which sets
  # VERBOSE=1. We mirror it under a local name so the row helpers below
  # don't have to know about the global.
  local rc=0 verbose="$VERBOSE"

  local fail_count=0 warn_count=0
  _bump_fail() { rc=4; fail_count=$((fail_count+1)); }
  _bump_warn() { (( rc < 1 )) && rc=1; warn_count=$((warn_count+1)); }
  _row_ok()   { printf '  %sok%s   %s\n'   "$C_G" "$C_X" "$*"; }
  _row_fail() { printf '  %sFAIL%s %s\n'   "$C_R" "$C_X" "$1"; [[ -n "${2:-}" && $verbose -eq 1 ]] && printf '       %s→ %s%s\n' "$C_D" "$2" "$C_X"; _bump_fail; }
  _row_warn() { printf '  %swarn%s %s\n'   "$C_Y" "$C_X" "$1"; [[ -n "${2:-}" && $verbose -eq 1 ]] && printf '       %s→ %s%s\n' "$C_D" "$2" "$C_X"; _bump_warn; }
  _row_dim()  { printf '  %s--%s   %s\n'   "$C_D" "$C_X" "$*"; }
  _row_info() { printf '  %sinfo%s %s\n'   "$C_G" "$C_X" "$*"; }

  printf 'spine doctor — %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  # ── 1. binaries ─────────────────────────────────────────────────
  printf '\n%s[1] host binaries%s\n' "$C_D" "$C_X"
  command -v docker >/dev/null 2>&1 \
    && _row_ok "docker present ($(docker --version 2>/dev/null | head -1))" \
    || _row_fail "docker not on PATH" "install Docker Desktop or 'brew install --cask docker'"
  if command -v python3 >/dev/null 2>&1 \
     && python3 -c 'import sys;sys.exit(0 if sys.version_info>=(3,10) else 1)' 2>/dev/null; then
    _row_ok "python3 $(python3 -c 'import sys;print("%d.%d.%d"%sys.version_info[:3])')"
  else
    _row_fail "python3 >= 3.10 missing" "'brew install python@3.12' or apt install python3.12"
  fi
  command -v psql >/dev/null 2>&1 \
    && _row_ok "psql present ($(psql --version 2>/dev/null | head -1))" \
    || _row_fail "psql not on PATH" "'brew install libpq' or apt install postgresql-client"
  command -v jq >/dev/null 2>&1 \
    && _row_ok "jq present (pretty-printing only)" \
    || _row_warn "jq missing — output won't be pretty-printed" "'brew install jq' / apt install jq"

  # ── 2. python venv + critical imports ───────────────────────────
  printf '\n%s[2] python venv + critical imports%s\n' "$C_D" "$C_X"
  if [[ -x "$SPINE_HOME/.venv/bin/python3" ]]; then
    _row_ok ".venv at $SPINE_HOME/.venv"
    local venv_py="$SPINE_HOME/.venv/bin/python3"
    local imp_out tool_n
    imp_out="$(SPINE_HOME="$SPINE_HOME" "$venv_py" - <<'PY' 2>&1
import sys, json, os
res = {}
for mod in ("mcp", "pydantic", "yaml", "fastapi", "alembic", "psycopg2"):
    try: __import__(mod); res[mod] = "ok"
    except Exception as e: res[mod] = f"FAIL: {type(e).__name__}"
try:
    sys.path.insert(0, os.environ["SPINE_HOME"])
    from shared.mcp.tools import TOOL_REGISTRY, discover_tools
    discover_tools(); res["shared.mcp.tools"] = f"ok ({len(TOOL_REGISTRY)} tools)"
except Exception as e:
    res["shared.mcp.tools"] = f"FAIL: {type(e).__name__}: {e}"
print(json.dumps(res))
PY
)"
    if printf '%s' "$imp_out" | python3 -c 'import sys,json;d=json.load(sys.stdin); sys.exit(0 if all(v.startswith("ok") for v in d.values()) else 1)' 2>/dev/null; then
      tool_n="$(printf '%s' "$imp_out" | python3 -c 'import sys,json;print(json.load(sys.stdin)["shared.mcp.tools"])' 2>/dev/null)"
      _row_ok "all critical imports: $tool_n"
    else
      printf '%s' "$imp_out" | python3 -c 'import sys,json;d=json.load(sys.stdin)
for k,v in d.items():
    print(f"     {k}: {v}")' 2>/dev/null || printf '%s\n' "$imp_out" | sed 's/^/     /'
      _row_fail "critical imports broken — run 'make bootstrap' (or pip install -r requirements.txt)" \
        "make bootstrap"
    fi
  else
    _row_fail ".venv missing at $SPINE_HOME/.venv" "make bootstrap"
  fi

  # ── 3. spine postgres ───────────────────────────────────────────
  printf '\n%s[3] spine postgres%s\n' "$C_D" "$C_X"
  if _psql -c 'SELECT 1;' >/dev/null 2>&1; then
    _row_ok "reachable at $SPINE_DB_URL"
  else
    _row_fail "unreachable at $SPINE_DB_URL" "cd db && docker compose up -d postgres"
  fi

  # ── 4. spine schemas ────────────────────────────────────────────
  # File-level `IFS=$'\n\t'` means `for x in $space_separated_string`
  # won't word-split — use an explicit array.
  printf '\n%s[4] spine schemas%s\n' "$C_D" "$C_X"
  if _psql -c 'SELECT 1;' >/dev/null 2>&1; then
    local -a need=(spine_audit spine_calibration spine_eval spine_kg \
                   spine_lifecycle spine_memory spine_recording \
                   spine_verify_audit spine_verify_threat_intel)
    local present; present="$(_psql -c "SELECT nspname FROM pg_namespace WHERE nspname LIKE 'spine_%' ORDER BY 1;" 2>/dev/null)"
    local miss="" sch
    for sch in "${need[@]}"; do
      printf '%s\n' "$present" | grep -qx "$sch" || miss="$miss $sch"
    done
    if [[ -z "$miss" ]]; then
      _row_ok "all 9 spine_* schemas present"
    else
      _row_fail "missing schemas:$miss" "cd db && docker compose run --rm flyway -outOfOrder=true migrate"
    fi
  else
    _row_dim "skipped (postgres unreachable)"
  fi

  # ── 5. tron postgres ────────────────────────────────────────────
  # psql parses user+password from the URL itself; no need to split it.
  # Fail-closed guard: if the local-dev sentinel password leaks into a
  # non-loopback URL, refuse the connection. Rotate via vault path
  # `tron/postgres/password` for prod. See docs/V1_SHIP_CHECKLIST.md §4.
  printf '\n%s[5] tron postgres (verify/)%s\n' "$C_D" "$C_X"
  local tron_dev_pw="tron_LOCAL_DEV_ONLY_2026"
  local tron_db_url="${TRON_DATABASE_URL:-postgresql://tron:${tron_dev_pw}@127.0.0.1:33010/tron}"
  if [[ "$tron_db_url" == *"$tron_dev_pw"* && \
        "$tron_db_url" != *"127.0.0.1"* && \
        "$tron_db_url" != *"localhost"* ]]; then
    _row_fail "refused: local-dev sentinel password on non-loopback host" \
              "rotate vault path tron/postgres/password — see docs/V1_SHIP_CHECKLIST.md §4"
    return
  fi
  if psql "$tron_db_url" -A -t -X -q -v ON_ERROR_STOP=1 -c 'SELECT 1;' >/dev/null 2>&1; then
    local rev; rev="$(psql "$tron_db_url" -A -t -X -q -c 'SELECT version_num FROM alembic_version;' 2>/dev/null | tr -d ' \n')"
    if [[ -n "$rev" ]]; then
      _row_ok "reachable (alembic=$rev)"
    else
      _row_warn "reachable but alembic_version empty" "tools/_tron_alembic_upgrade.py (run via .venv/bin/python)"
    fi
  else
    _row_fail "unreachable at 127.0.0.1:33010" "cd verify && docker compose up -d postgres"
  fi

  # ── 6. TRON importable ──────────────────────────────────────────
  printf '\n%s[6] TRON in-process AuditManager%s\n' "$C_D" "$C_X"
  if [[ -x "$SPINE_HOME/.venv/bin/python3" && -d "$SPINE_HOME/verify/tron" ]]; then
    if "$SPINE_HOME/.venv/bin/python3" -c "
import sys
sys.path.insert(0, '$SPINE_HOME')
sys.path.insert(1, '$SPINE_HOME/verify')
from tron.agents.manager import AuditManager
AuditManager(secrets={})
" >/dev/null 2>&1; then
      _row_ok "tron.agents.manager.AuditManager constructable (empty secrets)"
    else
      _row_fail "AuditManager import/construct failed" "make bootstrap (pulls sqlalchemy[asyncio]+temporalio)"
    fi
  else
    _row_dim "skipped (.venv or verify/tron missing)"
  fi

  # ── 7. MCP transport ────────────────────────────────────────────
  printf '\n%s[7] mcp transport%s\n' "$C_D" "$C_X"
  if command -v mcp >/dev/null 2>&1; then
    _row_ok "stdio (mcp CLI on PATH)"
  elif [[ -n "$_SPINE_PY" && -d "$SPINE_HOME/shared/mcp" ]] \
       && "$_SPINE_PY" -c 'import sys; sys.path.insert(0, "'"$SPINE_HOME"'"); from shared.mcp.tools import TOOL_REGISTRY, discover_tools; discover_tools()' >/dev/null 2>&1; then
    _row_ok "in-process python ($_SPINE_PY)"
  elif [[ -n "${SPINE_MCP_HTTP_URL:-}" ]] && curl -fsS "$SPINE_MCP_HTTP_URL/health" >/dev/null 2>&1; then
    _row_ok "http ($SPINE_MCP_HTTP_URL)"
  else
    _row_warn "no transport reachable" "install 'mcp' CLI OR ensure .venv has shared.mcp tools OR set SPINE_MCP_HTTP_URL"
  fi

  # ── 8. bundle ───────────────────────────────────────────────────
  printf '\n%s[8] bundle config%s\n' "$C_D" "$C_X"
  if [[ -n "$SPINE_DEFAULT_BUNDLE" ]]; then
    _row_ok "default bundle: $SPINE_DEFAULT_BUNDLE"
  else
    _row_dim "no SPINE_DEFAULT_BUNDLE set (optional)"
  fi

  # ── 9. API keys ─────────────────────────────────────────────────
  printf '\n%s[9] LLM API keys (informational)%s\n' "$C_D" "$C_X"
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    _row_info "ANTHROPIC_API_KEY present (${#ANTHROPIC_API_KEY} chars)"
  else
    _row_dim "ANTHROPIC_API_KEY absent (deterministic scanners run without; LLM ISO agents need it)"
  fi
  if [[ -n "${OPENAI_API_KEY:-}" ]]; then
    _row_info "OPENAI_API_KEY present (${#OPENAI_API_KEY} chars)"
  else
    _row_dim "OPENAI_API_KEY absent (alternative to ANTHROPIC for LLM ISO agents)"
  fi

  # ── summary ─────────────────────────────────────────────────────
  printf '\n'
  if (( fail_count > 0 )); then
    printf '%sdoctor: %d FAIL, %d warn — fix above (use --verbose for hints) and re-run%s\n' \
      "$C_R" "$fail_count" "$warn_count" "$C_X"
  elif (( warn_count > 0 )); then
    printf '%sdoctor: %d warn (non-blocking)%s\n' "$C_Y" "$warn_count" "$C_X"
  else
    printf '%sdoctor: all green%s\n' "$C_G" "$C_X"
  fi
  return $rc
}

cmd_harness() {
  local harness_bin="${SPINE_HOME}/tools/harness/spine-harness"
  [[ -x "$harness_bin" ]] || _die 64 "harness CLI missing: $harness_bin (run from Spine repo root)"
  exec "$harness_bin" "$@"
}

cmd_help() {
  local topic="${REST_ARGS[0]:-}"
  [[ -n "$topic" ]] && { _help_for "$topic" >&2 || _die 64 "no help topic '$topic' (try: spine help)"; return 0; }
  cat <<'EOF'
spine — Spine orchestrator CLI (STORY-9.9.3)

Project lifecycle:
  spine project new <name> [--type T] [--description D] [--bundle B]
  spine project status <id> [--watch] [--format json|table|brief]
  spine project list|show|audit ...

Gates / transitions:
  spine project approve  <id> <phase> [--notes N] [--approver A]
  spine project reject   <id> <phase> --reason R   [--approver A]
  spine project rollback <id> <target_phase> --reason R

Plan-phase intake (interactive):
  spine intake <project_id> [--template T] [--actor A]

Build handoff (STORY-7.2.2 / 7.2.3):
  spine build brief  <project_id>
  spine build report <project_id> --artifact <path> [--actor A]

Harness Lite (portable SDLC — no Hub required):
  spine harness init [--project PATH] [--symlink-skills]
  spine harness start <mode> [--project PATH]
  spine harness loop <interval> <mode> [--project PATH]
  spine harness status [--markdown] [--project PATH]
  spine harness verify [--roles qa,auditor] [--run-qa] [--markdown] [--project PATH]
  spine harness stop [--project PATH]
  Modes: bootstrap | feature | sprint-close | release-gate | watch

Portfolio / ops:  spine status | spine doctor | spine help [<topic>]
  spine status [--markdown [--write PATH] [--exit-code] [--ledger-root R]]
              # Default: phase-count table.
              # --markdown:   render SESSION_HANDOFF-style snapshot (V3 B5).
              # --write PATH: also persist the rendered markdown to PATH.
              # --exit-code:  exit 0 green / 1 warnings / 2 failures.

Global flags:     --quiet/-q  --verbose/-v  --dry-run  --format json|table|brief  --help/-h
Env:              SPINE_DB_URL  SPINE_MCP_HTTP_URL  SPINE_DEFAULT_BUNDLE  SPINE_DEFAULT_OWNER
                  SPINE_DECISION_LEDGER_ROOT  (default: ~/.spine/decision_ledger)
Exit codes:       0 ok  1 generic  2 invalid-input  3 gate-blocked  4 mcp/db-unreachable  64 unknown-cmd
See orchestrator/bin/README.md for details.
EOF
}

# ─── main dispatch ────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"; shift || true
  local sub=""
  [[ "$cmd" == "project" || "$cmd" == "build" || "$cmd" == "harness" ]] && { sub="${1:-}"; shift || true; }
  _parse_flags "$@"
  case "$cmd" in
    project) case "$sub" in
        new) cmd_project_new ;;          status)   cmd_project_status   ;;
        approve) cmd_project_approve ;;  reject)   cmd_project_reject   ;;
        rollback) cmd_project_rollback;; list)     cmd_project_list     ;;
        show) cmd_project_show ;;        audit)    cmd_project_audit    ;;
        ""|help|-h|--help) cmd_help ;;
        *) _die 64 "unknown project subcommand: $sub (try: spine help)" ;;
      esac ;;
    build) case "$sub" in
        brief)  cmd_build_brief ;;
        report) cmd_build_report ;;
        ""|help|-h|--help) cmd_help ;;
        *) _die 64 "unknown build subcommand: $sub (try: spine help)" ;;
      esac ;;
    harness) case "$sub" in
        init|start|loop|status|verify|audit|stop) cmd_harness "$sub" "${REST_ARGS[@]}" ;;
        ""|help|-h|--help) cmd_help ;;
        *) _die 64 "unknown harness subcommand: $sub (try: spine help)" ;;
      esac ;;
    status) cmd_status ;; doctor) cmd_doctor ;; intake) cmd_intake ;;
    help|-h|--help|"") cmd_help ;;
    *) _die 64 "unknown command: $cmd (try: spine help)" ;;
  esac
}
main "$@"
