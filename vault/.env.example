# Spine v3 — Vault env file template (NON-SECRET ONLY).
#
# Copy to vault/.env before `docker compose up`. The real vault/.env is
# gitignored. NEVER add recovery keys, unseal keys, root tokens, or KMS
# credentials here — those live in your OS keychain / KMS / paper envelope
# per vault/unseal/*.md.

# Image override (Spine-built image once published; defaults to upstream).
# SPINE_VAULT_IMAGE=spine/vault:v3

# Host port to expose the OpenBao API on (default 8200).
VAULT_HOST_PORT=8200

# Log verbosity: trace | debug | info | warn | error
VAULT_LOG_LEVEL=info
