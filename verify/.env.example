# ============================================================
# Tron Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================
#
# SECRETS POLICY:
# All secrets (API keys, passwords, tokens, signing keys) are stored
# in the container keyvault. The application reads them at runtime.
# This .env file contains ONLY non-secret configuration.
#
# Keyvault Secret Paths:
#   tron/db/password          → PostgreSQL password
#   tron/redis/password       → Redis password
#   tron/minio/user           → MinIO admin user
#   tron/minio/password       → MinIO admin password
#   tron/minio/kms-key        → MinIO KMS encryption key
#   tron/auth/secret-key      → Application secret key
#   tron/auth/jwt-secret      → JWT signing key
#   tron/auth/master-key      → Tron master API key
#   tron/auth/admin-password  → Optional Tron **product admin UI** password (browser login). If unset, /login accepts the master key as the password.
#   tron/llm/openai-key       → OpenAI API key
#   tron/llm/anthropic-key    → Anthropic API key (canonical after merge)
#   tron/anthropic-key        → Optional short-path alias; if set, overrides llm row at worker/API merge
#   tron/grafana/password     → Grafana admin password
#
# ============================================================

# ── Keyvault Connection ──
# The ONLY secret allowed in this file: the vault address and auth method.
# The vault token itself should be injected via container orchestrator
# (e.g., Kubernetes service account, Docker secret, or instance metadata).
VAULT_ADDR=http://vault:8200
VAULT_AUTH_METHOD=token
VAULT_SECRET_PREFIX=tron

# ── Database (non-secret config) ──
POSTGRES_DB=tron
POSTGRES_USER=tron
DATABASE_POOL_SIZE=20

# ── Redis (non-secret config) ──
REDIS_DB=0

# ── MinIO (non-secret config) ──
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=tron-artifacts
MINIO_SECURE=true

# ── Temporal (Workflow Engine) ──
TEMPORAL_HOST=temporal:7233
TEMPORAL_TASK_QUEUE=tron-tasks
TEMPORAL_MAX_CONCURRENT_ACTIVITIES=10
TEMPORAL_MAX_CONCURRENT_WORKFLOWS=20

# Default age (minutes) for POST /api/audits/reconcile-stale-queued when body omits older_than_minutes
TRON_STALE_QUEUED_AUDIT_MINUTES=120
# On tron-api startup, mark queued audits older than TRON_STALE_QUEUED_AUDIT_MINUTES as failed (clears Live UI zombies)
TRON_RECONCILE_STALE_QUEUED_ON_STARTUP=true

# ── Authentication (non-secret config) ──
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ── Cost Controls ──
COST_ALERT_THRESHOLD_DAILY=50.00
COST_HARD_LIMIT_DAILY=100.00
COST_PER_AUDIT_CAP=5.00

# Global LLM ledger cap (sum of llm_usage.cost_usd). Set TRON_LLM_BUDGET_ENFORCE=false in dev if needed.
TRON_LLM_BUDGET_USD=500
TRON_LLM_BUDGET_ENFORCE=true
TRON_LLM_SOFT_CAP_PCT=0.85

# Local Ollama (use model id `ollama/<model>` in code or agents)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# ── Monitoring (non-secret config) ──
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ── Agent Configuration ──
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=300
AGENT_TEMPERATURE_AUDIT=0.0
AGENT_TEMPERATURE_BUILD=0.2

# ── Verification Pipeline ──
VERIFICATION_REQUIRE_DETERMINISTIC_CONFIRM=true
VERIFICATION_CROSS_VALIDATION_ENABLED=true
VERIFICATION_CONFIDENCE_FLOOR=0.3
VERIFICATION_CRITICAL_CONSENSUS_THRESHOLD=2
VERIFICATION_SEMANTIC_VALIDATION_ENABLED=true
VERIFICATION_CALIBRATION_MIN_SAMPLES=200
VERIFICATION_PLATT_SCALING_MIN_SAMPLES=500

# ── Logging ──
LOG_LEVEL=INFO
LOKI_ENDPOINT=http://loki:3100

# ── API container: run `alembic upgrade head` at startup (compose default true). Set false if a job runs migrations.
TRON_AUTO_MIGRATE=true

# ── Agent handoff (after each completed audit) ──
# When ``projects.agent_handoff_path`` is set (absolute path the tron-worker can write), Tron refreshes
# TRON_POST_SCAN.md + .cursor/rules + CLAUDE.md + AGENTS.md there. Mount that repo on tron-worker in Docker.
TRON_AGENT_HANDOFF=true
# Append-only ``tron.md`` activity entries in the scanned repo (default true). Set false if you only want managed files.
TRON_HANDOFF_APPEND_TRON_MD=true
# URL embedded in generated markdown (Tron admin UI). Set on tron-worker and tron-api if you use handoff.
TRON_UI_BASE=http://localhost:13080

# ── Backup Configuration ──
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30

# ── LLM Circuit Breaker Settings ──
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_TIMEOUT=60
LLM_REQUEST_TIMEOUT=300
LLM_BULKHEAD_MAX_CONCURRENT=10

# ── Sandbox Configuration ──
SANDBOX_MAX_CONCURRENT=5
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_MEMORY_LIMIT=512
SANDBOX_CPU_LIMIT=1
SANDBOX_NETWORK_MODE=none
SANDBOX_READ_ONLY_FS=true
SANDBOX_RUNTIME=gvisor
# Remote sandbox (worker/API): HTTP keep-alive pool size toward TRON_SANDBOX_URL
# TRON_SANDBOX_HTTP_POOL_SIZE=10
# tron-sandbox container: optional startup warm-up executions (capped at 10)
# SANDBOX_PREWARM_EXECUTIONS=0

# ── Compliance reference packs (optional; comma-separated built-in pack ids) ──
# TRON_COMPLIANCE_PACKS=soc2_reference,hipaa_reference,iso27001_reference

# ── Observability ──
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ── Worker git (optional; set on Temporal worker environment, not API-only hosts) ──
# TRON_PLAN_GIT_TOKEN — PAT with repo write: pushes PLAN `.tron` / `.cursor` bundle to origin.
# TRON_BUILD_GIT_TOKEN — same idea for BUILD: pushes branch `tron/build-<run>` with `.tron/build-result.json`
#   (if unset, BUILD reuse-tries TRON_PLAN_GIT_TOKEN). See `tron/services/git_plan_bundle.py`,
#   `tron/services/git_build_report.py`.

# ── WebSocket ──
WS_REQUIRE_AUTH=true
WS_MAX_CONNECTIONS=100
