# verify/.env.vault-refs — Spine v3 vault-reference manifest for TRON.
#
# Per docs/V3_DESIGN_DECISIONS.md #9 (vault-only secrets, no exceptions),
# this file replaces the legacy plaintext verify/.env. Each entry maps a
# legacy TRON environment variable NAME to its canonical vault path.
#
# Format:
#   <VAR_NAME>=vault:<vault/path/to/secret>
#
# This file MUST NEVER contain a secret value. The Spine verify-pipeline
# launcher resolves each `vault:` reference at process start by calling
# `python3 -m shared.secrets.cli get <path>` and injecting the result
# into the child process environment for the lifetime of the container.
#
# Vault path namespace: tron/* (matches verify/.env.example documentation
# which already enumerates the canonical TRON keyvault paths).

# ── Postgres (TRON's own DB) ──
POSTGRES_PASSWORD=vault:tron/db/password

# ── Redis ──
REDIS_PASSWORD=vault:tron/redis/password

# ── MinIO ──
MINIO_USER=vault:tron/minio/user
MINIO_PASSWORD=vault:tron/minio/password
MINIO_KMS_KEY=vault:tron/minio/kms-key

# ── Grafana ──
GRAFANA_PASSWORD=vault:tron/grafana/password

# ── Auth / signing ──
SECRET_KEY=vault:tron/auth/secret-key
JWT_SECRET=vault:tron/auth/jwt-secret
TRON_MASTER_KEY=vault:tron/auth/master-key
TRON_ADMIN_PASSWORD=vault:tron/auth/admin-password

# ── LLM provider keys ──
OPENAI_API_KEY=vault:tron/llm/openai-key
ANTHROPIC_API_KEY=vault:tron/llm/anthropic-key
