# verify/.env — Spine-managed defaults for TRON's compose stack.
#
# Source of truth: verify/.env.example documents every variable. This file
# carries the minimum non-secret defaults Spine needs to bring TRON's
# postgres up in dev (`cd verify && docker compose up -d postgres`).
#
# DO NOT add real LLM API keys here. TRON reads them from a vault in prod;
# Spine's verify_audit wrapper reads ANTHROPIC_API_KEY / OPENAI_API_KEY
# from the shell env when running the in-process AuditManager.
#
# Standalone deployability (verify/SUBSYSTEM_BOUNDARY.md G-8): this file
# is fine to leave checked in — it contains only dev-only placeholders.

# ── Postgres (TRON's own DB; binds host 127.0.0.1:13002 — does not
#    collide with Spine's postgres on 33001) ──
POSTGRES_DB=tron
POSTGRES_USER=tron
POSTGRES_PASSWORD=tron_dev_only

# ── Redis / MinIO / Grafana — placeholders so `docker compose config`
#    doesn't warn. Spine's first-cut integration brings up postgres only;
#    these defaults only matter if you `docker compose up <service>`
#    explicitly. ──
REDIS_PASSWORD=tron_dev_only
MINIO_USER=tron
MINIO_PASSWORD=tron_dev_only
GRAFANA_PASSWORD=tron_dev_only
