# Tron Admin UI Environment Configuration

# API Configuration
# The API client will proxy requests to this URL + /api
# Development: http://localhost:13000 (local API)
# Production: https://tron.example.com (via Nginx reverse proxy)
VITE_API_BASE_URL=http://localhost:13000

# Environment
VITE_ENV=development

# Optional: Analytics or monitoring
# VITE_SENTRY_DSN=https://...
